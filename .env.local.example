# ── App ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://macropage.in

# ── MongoDB ──────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/macropage

# ── Redis (Upstash recommended) ──────────
REDIS_URL=redis://localhost:6379
# OR Upstash:
# REDIS_URL=rediss://<password>@<host>.upstash.io:6380

# ── Resend (Email) ───────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL=hello@macropage.in

# ── Sanity CMS ───────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=skxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Analytics ─────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
